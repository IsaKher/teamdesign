# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it is already in .gitignore.

# ─── Sanity CMS ──────────────────────────────────────────────────────────────
# Find these in your Sanity project dashboard: https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# ─── Site URL (used for CSRF protection in /api/contact) ─────────────────────
# Server-only — NOT prefixed with NEXT_PUBLIC_ intentionally.
# Set to your production domain. In local dev this defaults to https://teamdesign.in.
SITE_URL=https://teamdesign.in

# ─── Contact Form Email (choose ONE option below) ─────────────────────────────

# Option A — Resend (recommended, free tier available: https://resend.com)
# Uncomment the Resend block in app/api/contact/route.ts to activate.
RESEND_API_KEY=re_your_key_here

# Option B — SMTP / Nodemailer (Gmail, Outlook, etc.)
# Uncomment the Nodemailer block in app/api/contact/route.ts to activate.
# For Gmail, generate an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password_here
